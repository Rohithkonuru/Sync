# Production Environment Template
# Copy this to your Railway project's environment variables

# ==========================================
# CRITICAL - SET THESE FOR PRODUCTION
# ==========================================

# MongoDB Connection (Get from MongoDB Atlas)
# Example: mongodb+srv://user:pass@cluster0.xxx.mongodb.net/sync
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/sync

# JWT Secret (Generate a strong random string, 32+ characters)
JWT_SECRET=your-very-long-random-secret-key-at-least-32-characters-long

# ==========================================
# OPTIONAL - Default values work for most cases
# ==========================================

JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# CORS - Leave empty for multi-user production support
# CORS_ORIGINS=

# Upload directory
UPLOAD_DIR=./uploads

# ==========================================
# EMAIL CONFIGURATION (Optional)
# ==========================================

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_NAME=Sync Platform
SMTP_FROM_EMAIL=your-email@gmail.com

# ==========================================
# SMS CONFIGURATION (Optional)
# ==========================================

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx
